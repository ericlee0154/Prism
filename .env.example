# Local DuckDB path. Downloaded market data is ignored by Git.
PRISM_DATABASE_PATH=./data/prism.duckdb

# Server-side only. Never rename this to NEXT_PUBLIC_*.
MASSIVE_API_KEY=

# Server-side only. Used for source-grounded event research; no key means
# event research stays empty. Never rename either variable to NEXT_PUBLIC_*.
OPENAI_API_KEY=
OPENAI_EVENT_MODEL=gpt-5.6-sol
