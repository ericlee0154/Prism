# Local DuckDB path. Downloaded market data is ignored by Git.
PRISM_DATABASE_PATH=./data/prism.duckdb

# Server-side only. Never rename this to NEXT_PUBLIC_*.
MASSIVE_API_KEY=

# AI research runs through the local ChatGPT-authenticated Codex CLI.
# Massive remains the market-data provider.
PRISM_AI_PROVIDER=codex_cli
# Pinned for reproducible research; change explicitly to compare another model.
PRISM_CODEX_MODEL=gpt-5.6-sol
# Optional binary override; Prism also discovers `codex` from PATH or ChatGPT.app.
PRISM_CODEX_BIN=
PRISM_CODEX_TIMEOUT_SECONDS=300
